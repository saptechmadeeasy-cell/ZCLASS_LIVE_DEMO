    projection;
    strict ( 2 );
    use draft;

    define behavior for ZC_TRAVEL_AL alias Travel
    {
      use create;
      use update;
      use delete;

      use action Edit;
      use action Activate;
      use action Discard;
      use action Resume;
      use action Prepare;

      use association _BOOKING { create; with draft; }
    }

    define behavior for ZC_BOOKING_AL alias Booking
    {
      use update;
      use delete;

      use association _travel { with draft; }
    }